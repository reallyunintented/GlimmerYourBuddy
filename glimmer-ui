def set_permissions(path: Path, mode: int) -> None:
    try:
        path.chmod(mode)
    except (FileNotFoundError, PermissionError):
        pass


def ensure_private_dir(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True)
    set_permissions(path, PRIVATE_DIR_MODE)


def lock_path_for(path: Path) -> Path:
    return path.with_name(f".{path.name}.lock")


@contextmanager
def advisory_lock(path: Path):
    ensure_private_dir(path.parent)
    with open(path, "a+", encoding="utf-8") as handle:
        set_permissions(path, PRIVATE_FILE_MODE)
        if fcntl is not None:
            while True:
                try:
                    fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
                    break
                except OSError as exc:  # pragma: no cover - signal interruption
                    if exc.errno == errno.EINTR:
                        continue
                    raise
        try:
            yield
        finally:
            if fcntl is not None:
                fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def write_private_text(path: Path, content: str) -> None:
    ensure_private_dir(path.parent)
    fd, tmp_name = tempfile.mkstemp(
        dir=str(path.parent),
        prefix=f".{path.name}.",
        suffix=".tmp",
    )
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        set_permissions(tmp_path, PRIVATE_FILE_MODE)
        os.replace(tmp_path, path)
        set_permissions(path, PRIVATE_FILE_MODE)
    except Exception:
        try:
            tmp_path.unlink()
        except FileNotFoundError:
            pass
        raise


def normalize_host_value(value: str | None) -> str:
    host = (value or "").strip()
    if host.startswith("["):
        closing = host.find("]")
        if closing != -1:
            return host[1:closing]
    if host.count(":") == 1:
        candidate, port = host.rsplit(":", 1)
        if port.isdigit():
            return candidate
    return host


def is_loopback_host(value: str | None) -> bool:
    host = normalize_host_value(value)
    if not host:
        return False
    if host == "localhost":
        return True
    try:
        return ipaddress.ip_address(host).is_loopback
    except ValueError:
        return False


def validate_bind_host(host: str, allow_remote: bool) -> None:
    if allow_remote or is_loopback_host(host):
        return
    raise SystemExit(
        "Refusing to bind glimmer-ui to a non-loopback host without --allow-remote."
    )


def validate_remote_auth(host: str, allow_remote: bool, auth_password: str | None) -> None:
    if not allow_remote or is_loopback_host(host):
        return
    if auth_password:
        return
    raise SystemExit(
        "Refusing remote glimmer-ui access without HTTP auth. "
        "Set GLIMMER_UI_AUTH_TOKEN or pass --auth-password-env."
    )


def url_host_for_display(host: str) -> str:
    normalized = normalize_host_value(host)
    if normalized == "0.0.0.0":
        return "127.0.0.1"
    if normalized in {"::", "[::]"}:
        return "localhost"
    return normalized or host


def parse_host_port(value: str | None, default_port: int | None = None) -> tuple[str | None, int | None]:
    if not value:
        return (None, default_port)
    parsed = urlparse(f"//{value}")
    host = parsed.hostname.lower() if parsed.hostname else None
    port = parsed.port if parsed.port is not None else default_port
    return (host, port)


def origin_matches_host(
    origin_value: str | None,
    host_value: str | None,
    default_port: int,
) -> bool:
    if not origin_value:
        return True
    parsed = urlparse(origin_value)
    if parsed.scheme not in {"http", "https"} or not parsed.netloc:
        return False
    host, port = parse_host_port(host_value, default_port)
    origin_host = parsed.hostname.lower() if parsed.hostname else None
    origin_port = parsed.port if parsed.port is not None else (
        443 if parsed.scheme == "https" else 80
    )
    return bool(host and origin_host == host and origin_port == port)


def authorization_matches_basic_auth(
    header_value: str | None,
    username: str,
    password: str,
) -> bool:
    if not header_value:
        return False
    scheme, _, token = header_value.partition(" ")
    if scheme.lower() != "basic" or not token:
        return False
    try:
        decoded = base64.b64decode(token, validate=True).decode("utf-8")
    except Exception:
        return False
    provided_user, sep, provided_password = decoded.partition(":")
    if not sep:
        return False
    return hmac.compare_digest(provided_user, username) and hmac.compare_digest(
        provided_password,
        password,
    )


def parse_timestamp(value: str | None) -> datetime | None:
    if not value:
        return None
    try:
        return datetime.fromisoformat(value)
    except ValueError:
        return None


def timestamp_sort_key(value: str | None) -> tuple[int, str]:
    parsed = parse_timestamp(value)
    if parsed is None:
        return (0, value or "")
    return (1, parsed.isoformat())


def truncate_text(value: str | None, limit: int = 100) -> str:
    text = (value or "").strip()
    if len(text) <= limit:
        return text
    return text[: limit - 1].rstrip() + "…"


def current_datetime(now: str | datetime | None = None) -> datetime:
    if isinstance(now, datetime):
        return now
    if isinstance(now, str):
        parsed = parse_timestamp(now)
        if parsed is not None:
            return parsed
    return datetime.now()


def days_since(value: str | None, *, now: str | datetime | None = None) -> int | None:
    parsed = parse_timestamp(value)
    if parsed is None:
        return None
    current = current_datetime(now)
    return max(0, (current.date() - parsed.date()).days)


def load_jsonl(path: Path) -> list[dict]:
    if not path.exists():
        return []
    entries = []
    for line in path.read_text(encoding="utf-8").splitlines():
        try:
            parsed = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(parsed, dict):
            entries.append(parsed)
    return entries


def load_manifests(path: Path) -> dict[str, dict]:
    manifests: dict[str, dict] = {}
    if not path.exists():
        return manifests
    for manifest_path in sorted(path.glob("*.json")):
        try:
            parsed = json.loads(manifest_path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            continue
        if not isinstance(parsed, dict):
            continue
        session_id = parsed.get("session_id") or manifest_path.stem
        manifests[session_id] = parsed
    return manifests


def load_matters(path: Path) -> dict[str, dict]:
    return _load_matters_unlocked(path)


def _load_matters_unlocked(path: Path) -> dict[str, dict]:
    if not path.exists():
        return {}
    try:
        parsed = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {}
    if not isinstance(parsed, dict):
        return {}
    matters = {}
    for bubble_id, value in parsed.items():
        if not isinstance(bubble_id, str) or not isinstance(value, dict):
            continue
        matters[bubble_id] = normalize_matter(value)
    return matters


def normalize_review_state(value: str | None, default: str = DEFAULT_REVIEW_STATE) -> str:
    review_state = str(value or default).strip().lower()
    review_state = REVIEW_STATE_ALIASES.get(review_state, review_state)
    if review_state not in REVIEW_STATES:
        return default
    return review_state


def normalize_matter(value: dict | None) -> dict:
    value = value if isinstance(value, dict) else {}
    review_state = normalize_review_state(value.get("review_state"))
    return {
        "note": str(value.get("note") or "").strip(),
        "marked_at": value.get("marked_at"),
        "updated_at": value.get("updated_at"),
        "review_state": review_state,
        "reviewed_at": value.get("reviewed_at"),
    }


def save_matters(path: Path, matters: dict[str, dict]) -> None:
    with advisory_lock(lock_path_for(path)):
        _save_matters_unlocked(path, matters)


def _save_matters_unlocked(path: Path, matters: dict[str, dict]) -> None:
    normalized = {
        bubble_id: normalize_matter(value)
        for bubble_id, value in matters.items()
        if isinstance(bubble_id, str)
    }
    payload = json.dumps(normalized, ensure_ascii=False, indent=2, sort_keys=True) + "\n"
    write_private_text(path, payload)


def mutate_matters(path: Path, callback):
    with advisory_lock(lock_path_for(path)):
        matters = _load_matters_unlocked(path)
        result = callback(matters)
        _save_matters_unlocked(path, matters)
        return result


def load_usage(path: Path) -> dict[str, dict]:
    return _load_usage_unlocked(path)


def _load_usage_unlocked(path: Path) -> dict[str, dict]:
    if not path.exists():
        return {}
    try:
        parsed = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {}
    if not isinstance(parsed, dict):
        return {}
    usage = {}
    for bubble_id, value in parsed.items():
        if not isinstance(bubble_id, str) or not isinstance(value, dict):
            continue
        usage[bubble_id] = normalize_usage(value)
    return usage


def normalize_usage(value: dict | None) -> dict:
    value = value if isinstance(value, dict) else {}
    last_used_at = value.get("last_used_at")
    if not isinstance(last_used_at, str) or not last_used_at.strip():
        last_used_at = None
    try:
        use_count = int(value.get("use_count") or 0)
    except (TypeError, ValueError):
        use_count = 0
    use_count = max(0, use_count)
    raw_sources = value.get("use_sources")
    if not isinstance(raw_sources, list):
        raw_sources = []
    use_sources = sorted(
        {
            str(source).strip()
            for source in raw_sources
            if str(source).strip() in USAGE_SOURCES
        }
    )
    return {
        "last_used_at": last_used_at,
        "use_count": use_count,
        "use_sources": use_sources,
    }


def save_usage(path: Path, usage: dict[str, dict]) -> None:
    with advisory_lock(lock_path_for(path)):
        _save_usage_unlocked(path, usage)


def _save_usage_unlocked(path: Path, usage: dict[str, dict]) -> None:
    payload = json.dumps(usage, ensure_ascii=False, indent=2, sort_keys=True) + "\n"
    write_private_text(path, payload)


def mutate_usage(path: Path, callback):
    with advisory_lock(lock_path_for(path)):
        usage = _load_usage_unlocked(path)
        result = callback(usage)
        _save_usage_unlocked(path, usage)
        return result


def apply_usage(bubbles: list[dict], usage: dict[str, dict]) -> None:
    for bubble in bubbles:
        record = usage.get(bubble["id"])
        if not record:
            bubble["last_used_at"] = None
            bubble["use_count"] = 0
            bubble["use_sources"] = []
            continue
        bubble["last_used_at"] = record.get("last_used_at")
        bubble["use_count"] = int(record.get("use_count") or 0)
        bubble["use_sources"] = list(record.get("use_sources") or [])


def staleness_priority_value(bucket: str | None) -> int:
    return {
        "active": 0,
        "fading": 1,
        "stale": 2,
    }.get(bucket, -1)


def derive_staleness(bubble: dict) -> tuple[str | None, str | None]:
    if not bubble.get("mattered"):
        return (None, None)

    review_state = bubble.get("review_state") or DEFAULT_REVIEW_STATE
    use_count = int(bubble.get("use_count") or 0)
    days_used = bubble.get("days_since_used")
    days_mattered = bubble.get("days_since_mattered")

    if days_used is not None and days_used <= ACTIVE_USE_DAYS:
        return ("active", f"Revisited {days_used} day{'s' if days_used != 1 else ''} ago.")

    if use_count >= HIGH_USE_COUNT:
        if days_used is None or days_used <= STALE_USED_UNUSED_DAYS:
            return ("active", f"Revisited {use_count} times, so it is still showing life.")
        return ("fading", f"Revisited {use_count} times before, but not recently.")

    if review_state == "active":
        open_days = days_used if days_used is not None else days_mattered
        if open_days is not None and open_days >= STALE_OPEN_UNUSED_DAYS:
            return ("stale", f"Still active, but untouched for {open_days} days.")
        if open_days is not None and open_days >= FADING_UNUSED_DAYS:
            return (
                "fading",
                f"Still active, but cooling off after {open_days} days without a revisit.",
            )
        return ("active", "Still active in the review loop.")

    if use_count == 0:
        if days_mattered is not None and days_mattered >= STALE_NEVER_USED_DAYS:
            return (
                "stale",
                f"Marked mattered {days_mattered} days ago, but never revisited.",
            )
        if days_mattered is not None and days_mattered >= FADING_UNUSED_DAYS:
            return (
                "fading",
                f"Marked mattered {days_mattered} days ago, but not revisited yet.",
            )
        return ("active", "Freshly marked and still within the active window.")

    if days_used is not None and days_used >= STALE_USED_UNUSED_DAYS:
        return ("stale", f"Handled before, but not revisited for {days_used} days.")
    if days_used is not None and days_used >= FADING_UNUSED_DAYS:
        return (
            "fading",
            f"Handled before, but revisit activity has cooled off for {days_used} days.",
        )
    return ("active", "Still active from recent revisit activity.")


def apply_staleness(bubbles: list[dict], *, now: str | datetime | None = None) -> None:
    for bubble in bubbles:
        bubble["days_since_used"] = days_since(bubble.get("last_used_at"), now=now)
        bubble["days_since_mattered"] = (
            days_since(bubble.get("mattered_at"), now=now)
            if bubble.get("mattered")
            else None
        )
        staleness_bucket, staleness_reason = derive_staleness(bubble)
        bubble["staleness_bucket"] = staleness_bucket
        bubble["staleness_reason"] = staleness_reason


def record_usage(
    usage: dict[str, dict],
    bubble_ids: list[str],
    source: str,
    *,
    known_bubble_ids: set[str] | None = None,
    now: str | None = None,
) -> list[str]:
    if source not in USAGE_SOURCES:
        raise ValueError(f"usage source must be one of: {', '.join(sorted(USAGE_SOURCES))}")
    seen = set()
    recorded = []
    timestamp = now or datetime.now().isoformat()
    for bubble_id in bubble_ids:
        if not isinstance(bubble_id, str):
            continue
        normalized_bubble_id = bubble_id.strip()
        if not normalized_bubble_id or normalized_bubble_id in seen:
            continue
        seen.add(normalized_bubble_id)
        if known_bubble_ids is not None and normalized_bubble_id not in known_bubble_ids:
            continue
        existing = normalize_usage(usage.get(normalized_bubble_id))
        sources = set(existing.get("use_sources") or [])
        sources.add(source)
        usage[normalized_bubble_id] = {
            "last_used_at": timestamp,
            "use_count": int(existing.get("use_count") or 0) + 1,
            "use_sources": sorted(sources),
        }
        recorded.append(normalized_bubble_id)
    return recorded


def known_bubble_ids(index: dict) -> set[str]:
    return {
        bubble.get("id")
        for bubble in index.get("bubbles") or []
        if isinstance(bubble.get("id"), str)
    }


def record_usage_for_index(
    glimmer_dir: Path,
    index: dict,
    bubble_ids: list[str],
    source: str,
    *,
    now: str | None = None,
) -> list[str]:
    usage_path = glimmer_dir / USAGE_FILE
    return mutate_usage(
        usage_path,
        lambda usage: record_usage(
            usage,
            bubble_ids,
            source,
            known_bubble_ids=known_bubble_ids(index),
            now=now,
        ),
    )


def bubble_id(entry: dict) -> str:
    raw = "|".join(
        [
            entry.get("timestamp") or "",
            entry.get("session_id") or "",
            str(entry.get("bubble_seq") or ""),
            entry.get("companion") or "",
            entry.get("text") or "",
        ]
    )
    return hashlib.sha1(raw.encode("utf-8")).hexdigest()[:16]


def normalize_bubble(entry: dict, source: str) -> dict:
    normalized = {
        "timestamp": entry.get("timestamp"),
        "companion": entry.get("companion") or "Glimmer",
        "text": entry.get("text") or "",
        "source": entry.get("source") or source,
        "session_id": entry.get("session_id"),
        "bubble_seq": entry.get("bubble_seq"),
        "trigger_type": entry.get("trigger_type"),
        "trigger_confidence": entry.get("trigger_confidence"),
        "trigger_text": entry.get("trigger_text"),
        "cwd": entry.get("cwd"),
        "project_root": entry.get("project_root"),
        "project_name": entry.get("project_name"),
        "git_branch": entry.get("git_branch"),
        "is_repo_root": entry.get("is_repo_root"),
        "raw_path": entry.get("raw_path"),
    }
    normalized["id"] = bubble_id(normalized)
    normalized["preview"] = truncate_text(normalized["text"], 120)
    normalized["mattered"] = False
    normalized["matter_note"] = ""
    normalized["mattered_at"] = None
    normalized["matter_updated_at"] = None
    normalized["review_state"] = None
    normalized["reviewed_at"] = None
    normalized["days_since_used"] = None
    normalized["days_since_mattered"] = None
    normalized["staleness_bucket"] = None
    normalized["staleness_reason"] = None
    return normalized


def session_field(manifest: dict, bubbles: list[dict], key: str):
    if key in manifest:
        return manifest.get(key)
    if bubbles:
        return bubbles[0].get(key)
    return None


def bubble_sort_desc(entry: dict) -> tuple[tuple[int, str], str]:
    return (timestamp_sort_key(entry.get("timestamp")), entry.get("id", ""))


def bubble_sort_session(entry: dict) -> tuple[int, tuple[int, str], str]:
    bubble_seq = entry.get("bubble_seq")
    if isinstance(bubble_seq, int):
        return (0, (1, f"{bubble_seq:09d}"), entry.get("id", ""))
    return (1, timestamp_sort_key(entry.get("timestamp")), entry.get("id", ""))


def dedupe_bubbles(events: list[dict], legacy: list[dict]) -> list[dict]:
    normalized_events = [normalize_bubble(entry, "auto") for entry in events]
    event_keys = {
        (
            entry.get("timestamp"),
            entry.get("companion"),
            entry.get("text"),
        )
        for entry in events
    }

    bubbles = list(normalized_events)
    for entry in legacy:
        key = (
            entry.get("timestamp"),
            entry.get("companion"),
            entry.get("text"),
        )
        if key in event_keys:
            continue
        bubbles.append(normalize_bubble(entry, entry.get("source") or "legacy"))

    bubbles.sort(key=bubble_sort_desc, reverse=True)
    return bubbles


def apply_matters(bubbles: list[dict], matters: dict[str, dict]) -> None:
    for bubble in bubbles:
        matter = matters.get(bubble["id"])
        if not matter:
            continue
        bubble["mattered"] = True
        bubble["matter_note"] = matter.get("note") or ""
        bubble["mattered_at"] = matter.get("marked_at")
        bubble["matter_updated_at"] = matter.get("updated_at")
        bubble["review_state"] = matter.get("review_state") or DEFAULT_REVIEW_STATE
        bubble["reviewed_at"] = matter.get("reviewed_at")


def upsert_matter(
    matters: dict[str, dict],
    bubble_id: str,
    *,
    marked: bool,
    note: str,
    now: str | None = None,
) -> dict | None:
    if not marked:
        matters.pop(bubble_id, None)
        return None

    timestamp = now or datetime.now().isoformat()
    existing = normalize_matter(matters.get(bubble_id))
    matter = {
        "note": note.strip(),
        "marked_at": existing.get("marked_at") or timestamp,
        "updated_at": timestamp,
        "review_state": existing.get("review_state") or DEFAULT_REVIEW_STATE,
        "reviewed_at": existing.get("reviewed_at"),
    }
    matters[bubble_id] = matter
    return matter


def update_review_state(
    matters: dict[str, dict],
    bubble_id: str,
    review_state: str,
    *,
    now: str | None = None,
) -> dict:
    normalized_review_state = normalize_review_state(review_state, default="")
    if normalized_review_state not in REVIEW_STATES:
        raise ValueError(f"review_state must be one of: {', '.join(REVIEW_STATES)}")

    matter = matters.get(bubble_id)
    if matter is None:
        raise KeyError(bubble_id)

    timestamp = now or datetime.now().isoformat()
    normalized = normalize_matter(matter)
    normalized["review_state"] = normalized_review_state
    normalized["reviewed_at"] = (
        None if normalized_review_state == DEFAULT_REVIEW_STATE else timestamp
    )
    normalized["updated_at"] = timestamp
    matters[bubble_id] = normalized
    return normalized


def mattered_sort_key(bubble: dict) -> tuple[tuple[int, str], tuple[int, str], str]:
    return (
        timestamp_sort_key(bubble.get("mattered_at")),
        timestamp_sort_key(bubble.get("timestamp")),
        bubble.get("id", ""),
    )


def review_sort_key(bubble: dict) -> tuple[tuple[int, str], tuple[int, str], tuple[int, str], str]:
    return (
        timestamp_sort_key(bubble.get("reviewed_at")),
        timestamp_sort_key(bubble.get("mattered_at")),
        timestamp_sort_key(bubble.get("timestamp")),
        bubble.get("id", ""),
    )


def mattered_bubbles(index: dict) -> list[dict]:
    return [bubble for bubble in index["bubbles"] if bubble.get("mattered")]


def recurrence_text_for_bubble(bubble: dict) -> str:
    return " ".join(
        part.strip().lower()
        for part in (
            str(bubble.get("matter_note") or ""),
            str(bubble.get("text") or ""),
        )
        if part
    )


def recurrence_tokens_for_bubble(bubble: dict) -> list[str]:
    tokens = []
    for token in recurrence_text_for_bubble(bubble).split():
        cleaned = "".join(char for char in token if char.isalnum())
        if len(cleaned) < 4 or cleaned.isdigit():
            continue
        if cleaned in RECURRENCE_STOP_WORDS:
            continue
        tokens.append(cleaned)
    return sorted(set(tokens))


def recurrence_matches_for_bubble(index: dict, bubble: dict, limit: int = 3) -> list[dict]:
    base_tokens = recurrence_tokens_for_bubble(bubble)
    if not base_tokens:
        return []
    base_token_set = set(base_tokens)
    matches = []
    for candidate in mattered_bubbles(index):
        if candidate.get("id") == bubble.get("id"):
            continue
        shared_tokens = [
            token
            for token in recurrence_tokens_for_bubble(candidate)
            if token in base_token_set
        ]
        same_project = bool(
            bubble.get("project_name")
            and candidate.get("project_name")
            and bubble.get("project_name") == candidate.get("project_name")
        )
        score = len(shared_tokens) + (1 if same_project else 0)
        if len(shared_tokens) < 2 and not (same_project and shared_tokens):
            continue
        matches.append(
            {
                "bubble": candidate,
                "same_project": same_project,
                "shared_tokens": shared_tokens,
                "score": score,
            }
        )
    matches.sort(
        key=lambda entry: (entry["score"], review_sort_key(entry["bubble"])),
        reverse=True,
    )
    return matches[:limit]


def brief_bubble_ids(brief: dict) -> list[str]:
    bubble_ids = []
    for bubble in brief.get("top_mattered") or []:
        if bubble.get("id"):
            bubble_ids.append(bubble["id"])
    for bubble in brief.get("open_items") or []:
        if bubble.get("id"):
            bubble_ids.append(bubble["id"])
    for entry in brief.get("recurring_signals") or []:
        bubble = entry.get("bubble") or {}
        if bubble.get("id"):
            bubble_ids.append(bubble["id"])
    for bubble in brief.get("resurface_now") or []:
        if bubble.get("id"):
            bubble_ids.append(bubble["id"])
    return bubble_ids


def review_bubble_ids(review: dict) -> list[str]:
    bubble_ids = []
    for bubbles in (review.get("groups") or {}).values():
        for bubble in bubbles or []:
            if bubble.get("id"):
                bubble_ids.append(bubble["id"])
    return bubble_ids


def build_resurface_hints(index: dict) -> list[dict]:
    mattered = mattered_bubbles(index)
    unreviewed_with_notes = sorted(
        [
            bubble
            for bubble in mattered
            if bubble.get("review_state") == DEFAULT_REVIEW_STATE
            and str(bubble.get("matter_note") or "").strip()
        ],
        key=review_sort_key,
        reverse=True,
    )
    oldest_active = sorted(
        [bubble for bubble in mattered if bubble.get("review_state") == "active"],
        key=mattered_sort_key,
    )
    recurring = sorted(
        [
            {
                "bubble": bubble,
                "matches": recurrence_matches_for_bubble(index, bubble),
            }
            for bubble in mattered
        ],
        key=lambda entry: (
            len(entry["matches"]),
            review_sort_key(entry["bubble"]),
        ),
        reverse=True,
    )
    cooling_off = sorted(
        [
            bubble
            for bubble in mattered
            if bubble.get("staleness_bucket") in {"fading", "stale"}
        ],
        key=lambda bubble: (
            staleness_priority_value(bubble.get("staleness_bucket")),
            bubble.get("days_since_used")
            if bubble.get("days_since_used") is not None
            else bubble.get("days_since_mattered") or -1,
            review_sort_key(bubble),
        ),
        reverse=True,
    )

    hints = []
    if unreviewed_with_notes:
        hints.append(
            {
                "key": "needs_review",
                "label": "Needs first review",
                "copy": "Marked with a note, but still unreviewed.",
                "bubble": unreviewed_with_notes[0],
            }
        )
    if oldest_active:
        hints.append(
            {
                "key": "oldest_active",
                "label": "Oldest active",
                "copy": "Has stayed active the longest in your review loop.",
                "bubble": oldest_active[0],
            }
        )
    if recurring and recurring[0]["matches"]:
        hints.append(
            {
                "key": "recurring",
                "label": "Recurring signal",
                "copy": (
                    "Shares themes with "
                    f'{len(recurring[0]["matches"])} other mattered bubble'
                    f'{"s" if len(recurring[0]["matches"]) != 1 else ""}.'
                ),
                "bubble": recurring[0]["bubble"],
            }
        )
    if cooling_off:
        hints.append(
            {
                "key": "cooling_off",
                "label": "Needs return",
                "copy": cooling_off[0].get("staleness_reason")
                or "Worth pulling back into attention.",
                "bubble": cooling_off[0],
            }
        )
    return hints


def build_mattered_view(index: dict) -> dict:
    bubbles = sorted(
        mattered_bubbles(index),
        key=mattered_sort_key,
        reverse=True,
    )
    counts = {"mattered": len(bubbles)}
    for review_state in REVIEW_STATES:
        counts[review_state] = sum(
            1
            for bubble in bubbles
            if bubble.get("review_state") == review_state
        )
    counts["open"] = counts["active"]
    counts["used"] = counts["resolved"]
    return {
        "generated_at": index["generated_at"],
        "count": len(bubbles),
        "counts": counts,
        "bubbles": bubbles,
    }


def build_review_view(index: dict) -> dict:
    mattered = build_mattered_view(index)["bubbles"]
    groups = {}
    for review_state in REVIEW_STATES:
        groups[review_state] = [
            bubble for bubble in mattered if bubble.get("review_state") == review_state
        ]
    return {
        "generated_at": index["generated_at"],
        "counts": {
            "mattered": len(mattered),
            **{review_state: len(groups[review_state]) for review_state in REVIEW_STATES},
            "open": len(groups["active"]),
            "used": len(groups["resolved"]),
        },
        "staleness_counts": {
            bucket: sum(1 for bubble in mattered if bubble.get("staleness_bucket") == bucket)
            for bucket in STALENESS_BUCKETS
        },
        "groups": groups,
        "hints": build_resurface_hints(index),
    }


def normalize_context_path(value: str | None) -> str | None:
    if not value:
        return None
    expanded = os.path.expanduser(value)
    if os.path.isabs(expanded):
        return os.path.normpath(expanded)
    return os.path.normpath(os.path.join(os.getcwd(), expanded))


def infer_project_key(index: dict, cwd: str | None = None) -> str | None:
    normalized_cwd = normalize_context_path(cwd)
    if normalized_cwd:
        matches = []
        for session in index["sessions"]:
            project_key = session.get("project_label") or session.get("project_name")
            if not project_key:
                continue
            project_root = normalize_context_path(session.get("project_root"))
            session_cwd = normalize_context_path(session.get("cwd"))
            score = -1
            if project_root and (
                normalized_cwd == project_root
                or normalized_cwd.startswith(project_root + os.sep)
            ):
                score = len(project_root)
            elif session_cwd and normalized_cwd == session_cwd:
                score = len(session_cwd)
            if score >= 0:
                matches.append(
                    (
                        score,
                        timestamp_sort_key(
                            session.get("latest_bubble_at") or session.get("started_at")
                        ),
                        project_key,
                    )
                )
        if matches:
            matches.sort(reverse=True)
            return matches[0][2]

    mattered_projects = [
        project for project in index["projects"] if project.get("mattered_count")
    ]
    for project in mattered_projects:
        if project.get("project_key"):
            return project["project_key"]
    for project in index["projects"]:
        if project.get("project_key"):
            return project["project_key"]
    return None


def resolve_brief_scope(
    index: dict,
    *,
    project: str | None = None,
    session_id: str | None = None,
    cwd: str | None = None,
) -> dict:
    resolved_project = (project or "").strip() or None
    resolved_session = None
    source = "project" if resolved_project else None

    if session_id:
        if session_id == "latest":
            resolved_session = index["sessions"][0] if index["sessions"] else None
        else:
            resolved_session = next(
                (
                    candidate
                    for candidate in index["sessions"]
                    if candidate.get("session_id") == session_id
                ),
                None,
            )
        if resolved_session and not resolved_project:
            resolved_project = resolved_session.get("project_label")
            source = "session"

    if not resolved_project:
        resolved_project = infer_project_key(index, cwd)
        source = "cwd" if cwd and resolved_project else "fallback"

    project_record = next(
        (
            candidate
            for candidate in index["projects"]
            if candidate.get("project_key") == resolved_project
        ),
        None,
    )
    sessions = [
        session
        for session in index["sessions"]
        if session.get("project_label") == resolved_project
    ]
    bubbles = [
        bubble
        for bubble in mattered_bubbles(index)
        if (bubble.get("project_name") or "No Project") == resolved_project
    ]
    return {
        "project": project_record,
        "project_key": resolved_project,
        "project_label": (project_record or {}).get("project_label")
        or resolved_project
        or "All projects",
        "session": resolved_session,
        "sessions": sessions,
        "mattered_bubbles": bubbles,
        "source": source or "fallback",
        "cwd": normalize_context_path(cwd),
    }


def brief_priority_key(index: dict, bubble: dict) -> tuple:
    return (
        staleness_priority_value(bubble.get("staleness_bucket")),
        1 if str(bubble.get("matter_note") or "").strip() else 0,
        BRIEF_REVIEW_PRIORITY.get(
            bubble.get("review_state") or DEFAULT_REVIEW_STATE,
            0,
        ),
        len(recurrence_matches_for_bubble(index, bubble, limit=5)),
        timestamp_sort_key(
            bubble.get("matter_updated_at")
            or bubble.get("reviewed_at")
            or bubble.get("mattered_at")
        ),
        timestamp_sort_key(bubble.get("timestamp")),
        bubble.get("id", ""),
    )


def staleness_priority_key(index: dict, bubble: dict) -> tuple:
    age = bubble.get("days_since_used")
    if age is None:
        age = bubble.get("days_since_mattered") or -1
    return (
        staleness_priority_value(bubble.get("staleness_bucket")),
        1 if (bubble.get("review_state") or DEFAULT_REVIEW_STATE) == "active" else 0,
        age,
        -int(bubble.get("use_count") or 0),
        brief_priority_key(index, bubble),
    )


def build_brief_view(
    index: dict,
    *,
    project: str | None = None,
    session_id: str | None = None,
    cwd: str | None = None,
    limit: int = BRIEF_DEFAULT_LIMIT,
) -> dict:
    scope = resolve_brief_scope(index, project=project, session_id=session_id, cwd=cwd)
    mattered = sorted(
        scope["mattered_bubbles"],
        key=lambda bubble: brief_priority_key(index, bubble),
        reverse=True,
    )
    active_items = [
        bubble
        for bubble in mattered
        if (bubble.get("review_state") or DEFAULT_REVIEW_STATE)
        in {DEFAULT_REVIEW_STATE, "active"}
    ]
    recurring = []
    for bubble in mattered:
        matches = recurrence_matches_for_bubble(index, bubble, limit=5)
        if not matches:
            continue
        recurring.append(
            {
                "bubble": bubble,
                "match_count": len(matches),
                "same_project_match_count": sum(
                    1 for match in matches if match.get("same_project")
                ),
                "cross_project_match_count": sum(
                    1 for match in matches if not match.get("same_project")
                ),
                "shared_tokens": sorted(
                    {
                        token
                        for match in matches
                        for token in match.get("shared_tokens") or []
                    }
                )[:6],
                "matches": matches,
            }
        )
    recurring.sort(
        key=lambda entry: (
            entry["same_project_match_count"],
            entry["match_count"],
            brief_priority_key(index, entry["bubble"]),
        ),
        reverse=True,
    )
    resurface_now = sorted(
        [
            bubble
            for bubble in mattered
            if bubble.get("staleness_bucket") in {"fading", "stale"}
        ],
        key=lambda bubble: staleness_priority_key(index, bubble),
        reverse=True,
    )

    project_record = scope["project"] or {}
    counts = {review_state: 0 for review_state in REVIEW_STATES}
    for bubble in mattered:
        counts[bubble.get("review_state") or DEFAULT_REVIEW_STATE] += 1

    return {
        "generated_at": index["generated_at"],
        "scope": {
            "project_key": scope["project_key"],
            "project_label": scope["project_label"],
            "source": scope["source"],
            "cwd": scope["cwd"],
            "session_id": (scope["session"] or {}).get("session_id"),
        },
        "summary": {
            "bubble_count": project_record.get("bubble_count", 0),
            "session_count": project_record.get("session_count", len(scope["sessions"])),
            "mattered_count": len(mattered),
            "active_count": counts["active"],
            "unreviewed_count": counts[DEFAULT_REVIEW_STATE],
            "resolved_count": counts["resolved"],
            "stale_count": counts["stale"],
            "open_count": counts["active"],
            "used_count": counts["resolved"],
            "active_signal_count": sum(
                1 for bubble in mattered if bubble.get("staleness_bucket") == "active"
            ),
            "fading_signal_count": sum(
                1 for bubble in mattered if bubble.get("staleness_bucket") == "fading"
            ),
            "stale_signal_count": sum(
                1 for bubble in mattered if bubble.get("staleness_bucket") == "stale"
            ),
            "last_seen_at": project_record.get("last_seen_at"),
        },
        "project": project_record or None,
        "top_mattered": mattered[:limit],
        "open_items": active_items[:limit],
        "recurring_signals": recurring[:limit],
        "resurface_now": resurface_now[:limit],
    }


def build_search_view(index: dict, query: str, mattered_only: bool = False) -> dict:
    needle = query.strip().casefold()
    if not needle:
        return {
            "generated_at": index["generated_at"],
            "query": query,
            "count": 0,
            "bubbles": [],
        }

    bubbles = index["bubbles"]
    if mattered_only:
        bubbles = [bubble for bubble in bubbles if bubble.get("mattered")]

    matches = []
    for bubble in bubbles:
        haystack = " ".join(
            str(part or "")
            for part in (
                bubble.get("text"),
                bubble.get("matter_note"),
                bubble.get("project_name"),
                bubble.get("git_branch"),
                bubble.get("companion"),
                bubble.get("trigger_type"),
            )
        ).casefold()
        if needle in haystack:
            matches.append(bubble)

    return {
        "generated_at": index["generated_at"],
        "query": query,
        "count": len(matches),
        "bubbles": matches,
    }


def build_bubble_view(index: dict, bubble_id: str) -> dict | None:
    bubble = next(
        (candidate for candidate in index["bubbles"] if candidate.get("id") == bubble_id),
        None,
    )
    if bubble is None:
        return None

    session = next(
        (
            candidate
            for candidate in index["sessions"]
            if candidate.get("session_id") == bubble.get("session_id")
        ),
        None,
    )
    project = next(
        (
            candidate
            for candidate in index["projects"]
            if candidate.get("project_key") == (bubble.get("project_name") or "No Project")
        ),
        None,
    )
    previous_bubble = None
    next_bubble = None
    if session and session.get("bubbles"):
        bubbles = session["bubbles"]
        try:
            bubble_index = next(
                idx for idx, candidate in enumerate(bubbles) if candidate.get("id") == bubble_id
            )
        except StopIteration:
            bubble_index = -1
        if bubble_index >= 0:
            if bubble_index > 0:
                previous_bubble = bubbles[bubble_index - 1]
            if bubble_index + 1 < len(bubbles):
                next_bubble = bubbles[bubble_index + 1]
    related_mattered = sorted(
        [
            candidate
            for candidate in mattered_bubbles(index)
            if candidate.get("id") != bubble_id
            and candidate.get("project_name")
            and candidate.get("project_name") == bubble.get("project_name")
        ],
        key=review_sort_key,
        reverse=True,
    )[:3]
    return {
        "generated_at": index["generated_at"],
        "bubble": bubble,
        "session": session,
        "project": project,
        "previous_bubble": previous_bubble,
        "next_bubble": next_bubble,
        "related_mattered": related_mattered,
        "recurrence_matches": recurrence_matches_for_bubble(index, bubble),
    }


def build_sessions(
    events: list[dict],
    manifests: dict[str, dict],
    matters: dict[str, dict],
    usage: dict[str, dict],
    *,
    now: str | datetime | None = None,
) -> list[dict]:
    grouped: dict[str, list[dict]] = defaultdict(list)
    for entry in events:
        session_id = entry.get("session_id")
        if not session_id:
            continue
        grouped[session_id].append(normalize_bubble(entry, "auto"))

    sessions = []
    for session_id in set(grouped) | set(manifests):
        manifest = manifests.get(session_id, {})
        bubbles = sorted(grouped.get(session_id, []), key=bubble_sort_session)
        apply_matters(bubbles, matters)
        apply_usage(bubbles, usage)
        apply_staleness(bubbles, now=now)
        latest = bubbles[-1] if bubbles else None
        started_at = session_field(manifest, bubbles, "started_at") or (
            bubbles[0].get("timestamp") if bubbles else None
        )
        ended_at = session_field(manifest, bubbles, "ended_at")
        project_name = session_field(manifest, bubbles, "project_name")
        latest_seen = latest.get("timestamp") if latest else started_at
        sessions.append(
            {
                "session_id": session_id,
                "started_at": started_at,
                "ended_at": ended_at,
                "companion": session_field(manifest, bubbles, "companion")
                or "Glimmer",
                "raw_path": session_field(manifest, bubbles, "raw_path"),
                "cwd": session_field(manifest, bubbles, "cwd"),
                "project_root": session_field(manifest, bubbles, "project_root"),
                "project_name": project_name,
                "project_label": project_name or "No Project",
                "git_branch": session_field(manifest, bubbles, "git_branch"),
                "is_repo_root": bool(session_field(manifest, bubbles, "is_repo_root")),
                "bubble_count": len(bubbles),
                "mattered_count": sum(1 for bubble in bubbles if bubble.get("mattered")),
                "latest_bubble_preview": latest.get("preview") if latest else "",
                "latest_bubble_at": latest_seen,
                "bubbles": bubbles,
            }
        )

    sessions.sort(
        key=lambda entry: (
            timestamp_sort_key(entry.get("started_at")),
            entry.get("session_id", ""),
        ),
        reverse=True,
    )
    return sessions


def build_projects(sessions: list[dict]) -> list[dict]:
    grouped: dict[str, list[dict]] = defaultdict(list)
    for session in sessions:
        grouped[session.get("project_label") or "No Project"].append(session)

    projects = []
    for project_label, project_sessions in grouped.items():
        sorted_sessions = sorted(
            project_sessions,
            key=lambda entry: (
                timestamp_sort_key(
                    entry.get("latest_bubble_at") or entry.get("started_at")
                ),
                entry.get("session_id", ""),
            ),
            reverse=True,
        )
        latest = sorted_sessions[0]
        branches = sorted(
            {
                session.get("git_branch")
                for session in sorted_sessions
                if session.get("git_branch")
            }
        )
        projects.append(
            {
                "project_key": project_label,
                "project_name": latest.get("project_name"),
                "project_label": project_label,
                "bubble_count": sum(
                    session.get("bubble_count", 0) for session in sorted_sessions
                ),
                "session_count": len(sorted_sessions),
                "mattered_count": sum(
                    session.get("mattered_count", 0) for session in sorted_sessions
                ),
                "last_seen_at": latest.get("latest_bubble_at")
                or latest.get("started_at"),
                "latest_bubble_preview": latest.get("latest_bubble_preview", ""),
                "latest_session_id": latest.get("session_id"),
                "branches": branches,
            }
        )

    projects.sort(
        key=lambda entry: (
            timestamp_sort_key(entry.get("last_seen_at")),
            entry.get("project_label", ""),
        ),
        reverse=True,
    )
    return projects


def build_index(glimmer_dir: Path, *, now: str | datetime | None = None) -> dict:
    log_entries = load_jsonl(glimmer_dir / "log.jsonl")
    event_entries = load_jsonl(glimmer_dir / "events.jsonl")
    manifests = load_manifests(glimmer_dir / "sessions")
    matters = load_matters(glimmer_dir / MATTERS_FILE)
    usage = load_usage(glimmer_dir / USAGE_FILE)

    bubbles = dedupe_bubbles(event_entries, log_entries)
    apply_matters(bubbles, matters)
    apply_usage(bubbles, usage)
    apply_staleness(bubbles, now=now)
    sessions = build_sessions(event_entries, manifests, matters, usage, now=now)
    projects = build_projects(sessions)

    return {
        "generated_at": datetime.now().isoformat(),
        "glimmer_dir": str(glimmer_dir),
        "overview": {
            "bubble_count": len(bubbles),
            "session_count": len(sessions),
            "project_count": len(projects),
            "mattered_count": sum(1 for bubble in bubbles if bubble.get("mattered")),
        },
        "bubbles": bubbles,
        "sessions": sessions,
        "projects": projects,
    }


def resolve_ui_dir(script_path: Path) -> Path:
    env_dir = os.environ.get("GLIMMER_UI_STATIC_DIR")
    if env_dir:
        return Path(env_dir)

    local_dir = script_path.resolve().parent / "ui"
    if local_dir.exists():
        return local_dir

    return Path.home() / ".local" / "share" / "glimmer" / "ui"


class GlimmerUIHandler(BaseHTTPRequestHandler):
    server_version = "GlimmerUI/0.1"

    def log_message(self, _format: str, *_args) -> None:  # noqa: A003
        return

    @property
    def config(self) -> dict:
        return self.server.config  # type: ignore[attr-defined]

    def request_host_allowed(self) -> bool:
        if self.config.get("allow_remote"):
            return True
        host = self.headers.get("Host")
        if host is None:
            return True
        return is_loopback_host(host)

    def request_auth_allowed(self) -> bool:
        auth_password = self.config.get("auth_password")
        if not auth_password:
            return True
        return authorization_matches_basic_auth(
            self.headers.get("Authorization"),
            self.config.get("auth_user", "glimmer"),
            auth_password,
        )

    def request_origin_allowed(self) -> bool:
        host = self.headers.get("Host")
        if host is None:
            return True
        default_port = getattr(self.server, "server_port", 0)
        for header in ("Origin", "Referer"):
            value = self.headers.get(header)
            if value and not origin_matches_host(value, host, default_port):
                return False
        return True

    def send_security_headers(self) -> None:
        self.send_header("Cache-Control", "no-store")
        self.send_header("X-Content-Type-Options", "nosniff")
        self.send_header("X-Frame-Options", "DENY")
        self.send_header("Referrer-Policy", "no-referrer")
        self.send_header("Cross-Origin-Resource-Policy", "same-origin")
        self.send_header(
            "Content-Security-Policy",
            "default-src 'self'; "
            "style-src 'self'; "
            "script-src 'self'; "
            "img-src 'self' data:; "
            "connect-src 'self'; "
            "base-uri 'none'; "
            "frame-ancestors 'none'",
        )

    def send_auth_challenge(self) -> None:
        self.send_response(401)
        self.send_header(
            "WWW-Authenticate",
            'Basic realm="Glimmer", charset="UTF-8"',
        )
        self.send_security_headers()
        self.end_headers()

    def parse_json_body(self) -> dict | None:
        content_length = self.headers.get("Content-Length")
        if not content_length:
            return None
        try:
            length = int(content_length)
        except ValueError:
            return None
        raw = self.rfile.read(length)
        try:
            parsed = json.loads(raw.decode("utf-8"))
        except json.JSONDecodeError:
            return None
        return parsed if isinstance(parsed, dict) else None

    def send_json(self, payload: dict | list, status: int = 200) -> None:
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.send_security_headers()
        self.end_headers()
        self.wfile.write(data)

    def send_file(self, path: Path) -> None:
        if not path.exists() or not path.is_file():
            self.send_error(404)
            return

        content = path.read_bytes()
        content_type, _ = mimetypes.guess_type(path.name)
        self.send_response(200)
        self.send_header("Content-Type", content_type or "application/octet-stream")
        self.send_header("Content-Length", str(len(content)))
        self.send_security_headers()
        self.end_headers()
        self.wfile.write(content)

    def do_GET(self) -> None:  # noqa: N802
        if not self.request_host_allowed():
            self.send_error(403, "Host not allowed")
            return
        if not self.request_auth_allowed():
            self.send_auth_challenge()
            return
        parsed = urlparse(self.path)
        if parsed.path == "/api/health":
            self.send_json({"ok": True})
            return

        if parsed.path == "/api/index":
            self.send_json(build_index(self.config["glimmer_dir"]))
            return

        if parsed.path == "/api/mattered":
            index = build_index(self.config["glimmer_dir"])
            self.send_json(build_mattered_view(index))
            return

        if parsed.path == "/api/review":
            index = build_index(self.config["glimmer_dir"])
            self.send_json(build_review_view(index))
            return

        if parsed.path == "/api/brief":
            index = build_index(self.config["glimmer_dir"])
            params = parse_qs(parsed.query)
            project = (params.get("project") or [""])[0] or None
            session_id = (params.get("session") or [""])[0] or None
            cwd = (params.get("cwd") or [""])[0] or None
            source = (params.get("source") or [""])[0] or ""
            try:
                limit = int((params.get("limit") or [str(BRIEF_DEFAULT_LIMIT)])[0])
            except ValueError:
                limit = BRIEF_DEFAULT_LIMIT
            payload = build_brief_view(
                index,
                project=project,
                session_id=session_id,
                cwd=cwd,
                limit=max(1, min(limit, 10)),
            )
            if source == "ui.brief":
                record_usage_for_index(
                    self.config["glimmer_dir"],
                    index,
                    brief_bubble_ids(payload),
                    "ui.brief",
                )
            self.send_json(payload)
            return

        if parsed.path == "/api/search":
            index = build_index(self.config["glimmer_dir"])
            params = parse_qs(parsed.query)
            query = (params.get("q") or [""])[0]
            mattered_only = (params.get("mattered_only") or ["0"])[0] in {"1", "true", "yes"}
            self.send_json(build_search_view(index, query, mattered_only))
            return

        if parsed.path.startswith("/api/bubbles/"):
            index = build_index(self.config["glimmer_dir"])
            params = parse_qs(parsed.query)
            requested_source = (params.get("source") or [""])[0] or ""
            source = requested_source if requested_source in {"ui.search_open", "ui.detail"} else "ui.detail"
            bubble_id = parsed.path.rsplit("/", 1)[-1]
            payload = build_bubble_view(index, bubble_id)
            if payload is None:
                self.send_error(404, "Bubble not found")
                return
            record_usage_for_index(
                self.config["glimmer_dir"],
                index,
                [bubble_id],
                source,
            )
            self.send_json(payload)
            return

        if parsed.path in {"", "/"}:
            self.send_file(self.config["ui_dir"] / "index.html")
            return

        asset_path = (self.config["ui_dir"] / parsed.path.lstrip("/")).resolve()
        ui_root = self.config["ui_dir"].resolve()
        if ui_root in asset_path.parents or asset_path == ui_root:
            self.send_file(asset_path)
            return

        self.send_error(404)

    def do_POST(self) -> None:  # noqa: N802
        if not self.request_host_allowed():
            self.send_error(403, "Host not allowed")
            return
        if not self.request_auth_allowed():
            self.send_auth_challenge()
            return
        if not self.request_origin_allowed():
            self.send_error(403, "Cross-origin POST not allowed")
            return
        parsed = urlparse(self.path)
        if parsed.path not in {"/api/matters", "/api/review-state"}:
            self.send_error(404)
            return

        payload = self.parse_json_body()
        if payload is None:
            self.send_error(400, "Invalid JSON body")
            return

        bubble_id = str(payload.get("bubble_id") or "").strip()
        marked = bool(payload.get("marked"))
        note = str(payload.get("note") or "").strip()
        if not bubble_id:
            self.send_error(400, "bubble_id is required")
            return

        index = build_index(self.config["glimmer_dir"])
        if not any(bubble.get("id") == bubble_id for bubble in index["bubbles"]):
            self.send_error(404, "Bubble not found")
            return

        matters_path = self.config["glimmer_dir"] / MATTERS_FILE
        if parsed.path == "/api/matters":
            matter = mutate_matters(
                matters_path,
                lambda matters: upsert_matter(
                    matters,
                    bubble_id,
                    marked=marked,
                    note=note,
                ),
            )
            record_usage_for_index(
                self.config["glimmer_dir"],
                index,
                [bubble_id],
                "ui.matter_toggle",
            )
            self.send_json(
                {
                    "ok": True,
                    "bubble_id": bubble_id,
                    "matter": matter,
                }
            )
            return

        review_state = str(payload.get("review_state") or "").strip()
        try:
            matter = mutate_matters(
                matters_path,
                lambda matters: update_review_state(
                    matters,
                    bubble_id,
                    review_state,
                ),
            )
        except KeyError:
            self.send_error(400, "Bubble must be marked as mattered first")
            return
        except ValueError as exc:
            self.send_error(400, str(exc))
            return
        record_usage_for_index(
            self.config["glimmer_dir"],
            index,
            [bubble_id],
            "ui.review_state",
        )
        self.send_json(
            {
                "ok": True,
                "bubble_id": bubble_id,
                "matter": matter,
            }
        )


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run the local Glimmer UI.")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8767)
    parser.add_argument("--glimmer-dir", default=str(DEFAULT_GLIMMER_DIR))
    parser.add_argument("--no-open", action="store_true")
    parser.add_argument(
        "--auth-user",
        default="glimmer",
        help="HTTP Basic auth username when auth is enabled.",
    )
    parser.add_argument(
        "--auth-password-env",
        default="GLIMMER_UI_AUTH_TOKEN",
        help="Environment variable name that stores the HTTP Basic auth password.",
    )
    parser.add_argument(
        "--allow-remote",
        action="store_true",
        help="Allow binding to non-loopback hosts. Use only behind your own auth boundary.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    validate_bind_host(args.host, args.allow_remote)
    auth_password = os.environ.get(args.auth_password_env or "") or None
    validate_remote_auth(args.host, args.allow_remote, auth_password)
    glimmer_dir = Path(args.glimmer_dir).expanduser()
    ui_dir = resolve_ui_dir(Path(__file__))
    if not ui_dir.exists():
        raise SystemExit(f"UI assets not found: {ui_dir}")

    server = ThreadingHTTPServer((args.host, args.port), GlimmerUIHandler)
    server.config = {  # type: ignore[attr-defined]
        "glimmer_dir": glimmer_dir,
        "ui_dir": ui_dir,
        "allow_remote": args.allow_remote,
        "auth_user": args.auth_user,
        "auth_password": auth_password,
    }
    url = f"http://{url_host_for_display(args.host)}:{server.server_port}/"
    print(f"Glimmer UI running at {url}")
    print(f"Reading data from {glimmer_dir}")
    if args.allow_remote:
        print(
            "Remote access is enabled with HTTP auth. "
            f"Use username '{args.auth_user}' and the password from {args.auth_password_env}."
        )
    if not args.no_open:
        try:
            webbrowser.open(url)
        except Exception as exc:
            print(f"glimmer-ui: could not open browser: {exc}", file=sys.stderr)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
