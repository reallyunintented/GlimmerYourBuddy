#!/usr/bin/env python3
"""Glimmer MCP server — 5 read-only tools over stdio."""

from __future__ import annotations

import importlib.util
import json
import os
import re
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path

try:
    from mcp.server.fastmcp import FastMCP
except ImportError as exc:  # pragma: no cover - exercised in runtime fallback
    FastMCP = None
    MCP_IMPORT_ERROR = exc
else:
    MCP_IMPORT_ERROR = None

# ---------------------------------------------------------------------------
# Load glimmer-ui as a module (same pattern as tests/test_glimmer_ui.py)
# ---------------------------------------------------------------------------

def _resolve_glimmer_ui_path(script_path: Path) -> Path:
    candidates = [
        script_path.resolve().parent / "glimmer-ui",
        Path.home() / ".local" / "bin" / "glimmer-ui",
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return candidates[0]


_MODULE_PATH = _resolve_glimmer_ui_path(Path(__file__))
_loader = SourceFileLoader("glimmer_ui", str(_MODULE_PATH))
_spec = importlib.util.spec_from_loader("glimmer_ui", _loader)
_ui = importlib.util.module_from_spec(_spec)
_loader.exec_module(_ui)

# ---------------------------------------------------------------------------
# Glimmer directory & index helper
# ---------------------------------------------------------------------------

DEFAULT_GLIMMER_DIR = Path(os.environ.get("GLIMMER_DATA_DIR", Path.home() / ".claude" / "glimmer"))
DEFAULT_BRIEF_LIMIT = 3
MAX_BRIEF_LIMIT = 10
MAX_QUERY_CHARS = 500
MAX_SEARCH_RESULTS = 50
BUBBLE_ID_RE = re.compile(r"^[0-9a-f]{16}$")


def _build_index() -> dict:
    return _ui.build_index(DEFAULT_GLIMMER_DIR)


def _json_error(code: str, message: str, **details) -> dict:
    payload = {
        "error": {
            "code": code,
            "message": message,
        }
    }
    if details:
        payload["error"]["details"] = details
    return payload


def _normalize_limit(limit) -> int:
    try:
        parsed = int(limit)
    except (TypeError, ValueError):
        return DEFAULT_BRIEF_LIMIT
    return max(1, min(parsed, MAX_BRIEF_LIMIT))


def _normalize_query(query, *, allow_empty: bool = False) -> str | None:
    if query is None:
        return "" if allow_empty else None
    text = str(query).strip()
    if not text:
        return "" if allow_empty else None
    if len(text) > MAX_QUERY_CHARS:
        return None
    return text


def _normalize_bubble_id(bubble_id) -> str | None:
    if bubble_id is None:
        return None
    text = str(bubble_id).strip()
    if not text or not BUBBLE_ID_RE.fullmatch(text):
        return None
    return text


# ---------------------------------------------------------------------------
# Internal helpers (testable without MCP serialisation)
# ---------------------------------------------------------------------------


def _tool_get_brief(index, project=None, session_id=None, cwd=None, limit=3):
    limit = _normalize_limit(limit)
    return _ui.build_brief_view(
        index, project=project, session_id=session_id, cwd=cwd, limit=limit
    )


def _tool_list_mattered(index):
    return _ui.build_mattered_view(index)


def _tool_get_review(index):
    return _ui.build_review_view(index)


def _tool_search_bubbles(
    index,
    query=None,
    mattered_only=False,
    review_states=None,
    staleness=None,
    contexts=None,
    has_note=False,
    profile=None,
    limit=MAX_SEARCH_RESULTS,
    offset=0,
):
    normalized_query = _normalize_query(query, allow_empty=True)
    if normalized_query is None:
        return _json_error(
            "invalid_query",
            f"query must be empty or a string up to {MAX_QUERY_CHARS} characters",
        )
    return _ui.build_search_view(
        index,
        normalized_query,
        mattered_only=mattered_only,
        review_states=review_states,
        staleness=staleness,
        contexts=contexts,
        has_note=has_note,
        profile=profile,
        limit=limit,
        offset=offset,
    )


def _tool_get_bubble(index, bubble_id):
    normalized_bubble_id = _normalize_bubble_id(bubble_id)
    if normalized_bubble_id is None:
        return _json_error(
            "invalid_bubble_id",
            "bubble_id must be a 16-character lowercase hex Glimmer bubble id",
        )
    result = _ui.build_bubble_view(index, normalized_bubble_id)
    if result is None:
        return _json_error("bubble_not_found", "Bubble not found", bubble_id=normalized_bubble_id)
    return result


def _json_result(payload: dict) -> str:
    return json.dumps(payload, ensure_ascii=False, indent=2)


# ---------------------------------------------------------------------------
# MCP server & tool definitions
# ---------------------------------------------------------------------------

def get_brief(
    project: str | None = None,
    session_id: str | None = None,
    cwd: str | None = None,
    limit: int = DEFAULT_BRIEF_LIMIT,
) -> str:
    """Get a project brief: top mattered bubbles, active items, and recurring signals."""
    index = _build_index()
    payload = _tool_get_brief(index, project=project, session_id=session_id, cwd=cwd, limit=limit)
    _ui.record_usage_for_index(
        DEFAULT_GLIMMER_DIR,
        index,
        _ui.brief_bubble_ids(payload),
        "mcp.get_brief",
    )
    return _json_result(payload)


def list_mattered() -> str:
    """List all mattered bubbles sorted by recency."""
    index = _build_index()
    payload = _tool_list_mattered(index)
    _ui.record_usage_for_index(
        DEFAULT_GLIMMER_DIR,
        index,
        [bubble.get("id") for bubble in payload.get("bubbles") or []],
        "mcp.list_mattered",
    )
    return _json_result(payload)


def get_review() -> str:
    """Get mattered bubbles grouped by review state."""
    index = _build_index()
    payload = _tool_get_review(index)
    _ui.record_usage_for_index(
        DEFAULT_GLIMMER_DIR,
        index,
        _ui.review_bubble_ids(payload),
        "mcp.get_review",
    )
    return _json_result(payload)


def search_bubbles(
    query: str | None = None,
    mattered_only: bool = False,
    review_states: list[str] | None = None,
    staleness: list[str] | None = None,
    contexts: list[str] | None = None,
    has_note: bool = False,
    profile: str | None = None,
    limit: int = MAX_SEARCH_RESULTS,
    offset: int = 0,
) -> str:
    """Search bubbles by text plus optional mattered, review, staleness, note, profile, and context filters."""
    index = _build_index()
    payload = _tool_search_bubbles(
        index,
        query,
        mattered_only=mattered_only,
        review_states=review_states,
        staleness=staleness,
        contexts=contexts,
        has_note=has_note,
        profile=profile,
        limit=limit,
        offset=offset,
    )
    if "error" not in payload:
        _ui.record_usage_for_index(
            DEFAULT_GLIMMER_DIR,
            index,
            [bubble.get("id") for bubble in payload.get("bubbles") or []],
            "mcp.search_bubbles",
        )
    return _json_result(payload)


def get_bubble(bubble_id: str) -> str:
    """Get a single bubble by ID, including session and project context."""
    index = _build_index()
    payload = _tool_get_bubble(index, bubble_id)
    if "error" not in payload:
        _ui.record_usage_for_index(
            DEFAULT_GLIMMER_DIR,
            index,
            [payload.get("bubble", {}).get("id")],
            "mcp.get_bubble",
        )
    return _json_result(payload)


if FastMCP is not None:
    mcp_server = FastMCP("glimmer")
    mcp_server.tool()(get_brief)
    mcp_server.tool()(list_mattered)
    mcp_server.tool()(get_review)
    mcp_server.tool()(search_bubbles)
    mcp_server.tool()(get_bubble)
else:  # pragma: no cover - exercised through runtime fallback
    mcp_server = None


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

if __name__ == "__main__":
    if mcp_server is None:
        print(
            "Error: missing MCP runtime dependency. "
            "Run ./install.sh or install GLIMMER_MCP_PYPI_SPEC (default: mcp==1.26.0).",
            file=sys.stderr,
        )
        raise SystemExit(1)
    mcp_server.run(transport="stdio")
