#!/usr/bin/env bash
#
# glimmer-log — View Glimmer's captured speech bubbles.
#
# Usage:
#   glimmer-log                  Show all bubbles from legacy log.jsonl
#   glimmer-log -n 10            Show last 10 bubbles
#   glimmer-log --session latest Show newest session from events.jsonl
#   glimmer-log --sessions       List known sessions
#   glimmer-log --project NAME   List matching sessions
#   glimmer-log --grep TEXT      Search captured bubble text
#   glimmer-log --cleanup-raw    Remove old raw capture files
#   glimmer-log --json           Raw legacy JSONL output
#   glimmer-log --stats          Show legacy log statistics
#   glimmer-log --add "text"     Manually add a bubble
#

set -euo pipefail

LOGFILE="$HOME/.claude/glimmer/log.jsonl"
EVENTSFILE="$HOME/.claude/glimmer/events.jsonl"
SESSIONS_DIR="$HOME/.claude/glimmer/sessions"
RAW_DIR="$HOME/.claude/glimmer/raw"
GLIMMER_DIR="$HOME/.claude/glimmer"
CLEANUP_RAW_DAYS_DEFAULT=14

resolve_glimmer_ui_script() {
    local here
    here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -f "$here/glimmer-ui" ]; then
        echo "$here/glimmer-ui"
        return 0
    fi
    if [ -f "$HOME/.local/bin/glimmer-ui" ]; then
        echo "$HOME/.local/bin/glimmer-ui"
        return 0
    fi
    echo ""
}

GLIMMER_UI_SCRIPT="$(resolve_glimmer_ui_script)"

get_companion_name() {
    python3 -c "
import json, os
try:
    cfg = json.load(open(os.path.expanduser('~/.claude.json')))
    print(cfg.get('companion', {}).get('name', 'Glimmer'))
except: print('Glimmer')
" 2>/dev/null || echo "Glimmer"
}

require_logfile() {
    if [ ! -f "$LOGFILE" ]; then
        echo "No bubbles captured yet."
        echo "Run 'glimmer-claude' instead of 'claude' to start logging."
        exit 0
    fi
}

view_legacy() {
    local mode="$1"
    local limit="${2:-0}"
    local grep_text="${3:-}"
    python3 - "$LOGFILE" "$mode" "$limit" "$grep_text" <<'PY'
import json
import sys
from datetime import datetime
from pathlib import Path

logfile = Path(sys.argv[1])
mode = sys.argv[2]
limit = int(sys.argv[3])
grep_text = sys.argv[4]

entries = []
for line in logfile.read_text(encoding="utf-8").splitlines():
    try:
        entries.append(json.loads(line))
    except json.JSONDecodeError:
        pass

if grep_text:
    needle = grep_text.casefold()
    entries = [
        entry for entry in entries
        if needle in entry.get("text", "").casefold()
    ]

if mode == "json":
    if limit > 0:
        entries = entries[-limit:]
    for entry in entries:
        print(json.dumps(entry, ensure_ascii=False))
    sys.exit(0)

if not entries:
    print("No bubbles yet.")
    sys.exit(0)

if mode == "stats":
    print(f"Total bubbles captured: {len(entries)}")
    try:
        first = datetime.fromisoformat(entries[0]["timestamp"])
        last = datetime.fromisoformat(entries[-1]["timestamp"])
        print(f'First: {first.strftime("%Y-%m-%d %H:%M")}')
        print(f'Last:  {last.strftime("%Y-%m-%d %H:%M")}')
    except (KeyError, ValueError):
        pass
    avg_len = sum(len(entry.get("text", "")) for entry in entries) / len(entries)
    print(f"Average bubble length: {avg_len:.0f} chars")
    longest = max(entries, key=lambda entry: len(entry.get("text", "")))
    preview = longest["text"][:80]
    suffix = "..." if len(longest["text"]) > 80 else ""
    print(f'Longest: "{preview}{suffix}"')
    sys.exit(0)

if limit > 0:
    entries = entries[-limit:]

for entry in entries:
    ts = entry.get("timestamp", "")
    try:
        ts_str = datetime.fromisoformat(ts).strftime("%Y-%m-%d %H:%M")
    except ValueError:
        ts_str = ts[:16]
    name = entry.get("companion", "Glimmer")
    text = entry.get("text", "")
    print(f'  \033[2m{ts_str}\033[0m  \033[1;35m{name}\033[0m')
    print(f'  \033[3m"{text}"\033[0m')
    print()
PY
}

view_sessions() {
    local session_ref="${1:-}"
    local project_filter="${2:-}"
    local branch_filter="${3:-}"
    local cwd_filter="${4:-}"
    local repo_root_only="${5:-0}"
    python3 - "$EVENTSFILE" "$SESSIONS_DIR" "$session_ref" "$project_filter" "$branch_filter" "$cwd_filter" "$repo_root_only" <<'PY'
from collections import defaultdict
from datetime import datetime
import os
from pathlib import Path
import json
import sys

eventsfile = Path(sys.argv[1])
sessions_dir = Path(sys.argv[2])
session_ref = sys.argv[3] or None
project_filter = sys.argv[4] or None
branch_filter = sys.argv[5] or None
cwd_filter = sys.argv[6] or None
repo_root_only = sys.argv[7] == "1"


def parse_ts(value: str | None):
    if not value:
        return None
    try:
        return datetime.fromisoformat(value)
    except ValueError:
        return None


def format_ts(value: str | None, fallback: str = "") -> str:
    dt = parse_ts(value)
    if dt is None:
        return fallback or (value or "")
    return dt.strftime("%Y-%m-%d %H:%M")


def normalize_filter_path(value: str | None) -> str | None:
    if not value:
        return None
    expanded = os.path.expanduser(value)
    if os.path.isabs(expanded):
        return os.path.normpath(expanded)
    return os.path.normpath(os.path.join(os.getcwd(), expanded))


def abbreviate_path(value: str | None) -> str:
    if not value:
        return "-"
    home = str(Path.home())
    if value == home:
        return "~"
    if value.startswith(home + os.sep):
        return "~/" + value[len(home + os.sep):]
    return value


def cwd_summary(cwd: str | None, project_root: str | None) -> str:
    if not cwd:
        return "-"
    if project_root:
        try:
            relative = Path(cwd).relative_to(Path(project_root))
            return "." if str(relative) == "." else str(relative)
        except ValueError:
            pass
    return abbreviate_path(cwd)


def first_entry(entries: list[dict]) -> dict:
    return entries[0] if entries else {}


def get_field(manifest: dict, entries: list[dict], key: str):
    if key in manifest:
        return manifest.get(key)
    return first_entry(entries).get(key)


def session_sort_key(record: dict):
    started = parse_ts(record.get("started_at"))
    if started is not None:
        return started
    matching = [parse_ts(entry.get("timestamp")) for entry in record.get("entries", [])]
    matching = [dt for dt in matching if dt is not None]
    if matching:
        return max(matching)
    return datetime.min


events = []
if eventsfile.exists():
    for line in eventsfile.read_text(encoding="utf-8").splitlines():
        try:
            events.append(json.loads(line))
        except json.JSONDecodeError:
            pass

entries_by_session: dict[str, list[dict]] = defaultdict(list)
for entry in events:
    session_id = entry.get("session_id")
    if session_id:
        entries_by_session[session_id].append(entry)

manifests: dict[str, dict] = {}
if sessions_dir.exists():
    for manifest_path in sorted(sessions_dir.glob("*.json")):
        try:
            manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            continue
        if isinstance(manifest, dict):
            session_id = manifest.get("session_id") or manifest_path.stem
            manifests[session_id] = manifest

session_ids = set(entries_by_session)
session_ids.update(manifests)
records = []
for current_session_id in session_ids:
    manifest = manifests.get(current_session_id, {})
    entries = entries_by_session.get(current_session_id, [])
    record = {
        "session_id": current_session_id,
        "entries": entries,
        "started_at": get_field(manifest, entries, "started_at") or (
            first_entry(entries).get("timestamp") if entries else ""
        ),
        "ended_at": get_field(manifest, entries, "ended_at"),
        "companion": get_field(manifest, entries, "companion") or "Glimmer",
        "raw_path": get_field(manifest, entries, "raw_path"),
        "cwd": get_field(manifest, entries, "cwd"),
        "project_root": get_field(manifest, entries, "project_root"),
        "project_name": get_field(manifest, entries, "project_name"),
        "git_branch": get_field(manifest, entries, "git_branch"),
        "is_repo_root": bool(get_field(manifest, entries, "is_repo_root")),
    }
    records.append(record)

normalized_cwd_filter = normalize_filter_path(cwd_filter)
filtered_records = []
for record in records:
    if project_filter is not None and record.get("project_name") != project_filter:
        continue
    if branch_filter is not None and record.get("git_branch") != branch_filter:
        continue
    if normalized_cwd_filter is not None:
        record_cwd = record.get("cwd")
        if not record_cwd or os.path.normpath(record_cwd) != normalized_cwd_filter:
            continue
    if repo_root_only and not record.get("is_repo_root"):
        continue
    filtered_records.append(record)

if not filtered_records:
    if session_ids:
        print("No session-aware entries matched the requested filters.")
    else:
        print("No session-aware entries yet.")
    sys.exit(0)

sorted_records = sorted(filtered_records, key=session_sort_key, reverse=True)

if not session_ref:
    latest_id = sorted_records[0]["session_id"]
    for record in sorted_records:
        latest_mark = "  latest" if record["session_id"] == latest_id else ""
        ended_at = record.get("ended_at")
        state = "open" if not ended_at else f"ended {format_ts(ended_at)}"
        print(f'{format_ts(record.get("started_at"), record["session_id"])}  {record["session_id"]}{latest_mark}')
        print(f'  {record.get("companion", "Glimmer")}  {len(record.get("entries", []))} bubbles  {state}')
        print(
            f'  project={record.get("project_name") or "-"}  '
            f'branch={record.get("git_branch") or "-"}  '
            f'cwd={cwd_summary(record.get("cwd"), record.get("project_root"))}'
        )
    sys.exit(0)

if session_ref == "latest":
    record = sorted_records[0]
else:
    matching = [item for item in filtered_records if item["session_id"] == session_ref]
    if not matching:
        print(f"Session not found: {session_ref}", file=sys.stderr)
        sys.exit(1)
    record = matching[0]

entries = record.get("entries", [])

print(f'Session: {record["session_id"]}')
print(f'Companion: {record.get("companion", "Glimmer")}')
print(f'Started: {format_ts(record.get("started_at"), "unknown")}')
print(f'Ended: {format_ts(record.get("ended_at"), "open") if record.get("ended_at") else "open"}')
print(f'Bubbles: {len(entries)}')
print(f'Project: {record.get("project_name") or "-"}')
print(f'Branch: {record.get("git_branch") or "-"}')
print(f'CWD: {record.get("cwd") or "-"}')
print(f'Repo root: {record.get("project_root") or "-"}')
print(f'At repo root: {"yes" if record.get("is_repo_root") else "no"}')
if record.get("raw_path"):
    print(f'Raw: {record.get("raw_path")}')
print()

for entry in entries:
    ts = entry.get("timestamp", "")
    ts_str = format_ts(ts, ts[:16])
    header = f'  \033[2m{ts_str}\033[0m  \033[1;35m{entry.get("companion", "Glimmer")}\033[0m'
    if entry.get("bubble_seq") is not None:
        header += f'  \033[2m#{entry["bubble_seq"]}\033[0m'
    if entry.get("trigger_type") and entry.get("trigger_type") != "unknown":
        header += f'  \033[2m[{entry["trigger_type"]}]\033[0m'
    print(header)
    print(f'  \033[3m"{entry.get("text", "")}"\033[0m')
    print()
PY
}

add_bubble() {
    local text="$1"
    local ts
    local companion
    ts="$(date -u +%Y-%m-%dT%H:%M:%S+00:00)"
    companion="$(get_companion_name)"
    python3 - "$LOGFILE" "$ts" "$companion" "$text" <<'PY'
from contextlib import contextmanager
import errno
import json
import sys
from pathlib import Path

try:
    import fcntl
except ImportError:  # pragma: no cover - non-POSIX fallback
    fcntl = None

PRIVATE_DIR_MODE = 0o700
PRIVATE_FILE_MODE = 0o600


def set_permissions(path: Path, mode: int) -> None:
    try:
        path.chmod(mode)
    except (FileNotFoundError, PermissionError):
        pass


def ensure_private_parent(path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    set_permissions(path.parent, PRIVATE_DIR_MODE)


def lock_path_for(path: Path) -> Path:
    return path.with_name(f".{path.name}.lock")


@contextmanager
def advisory_lock(path: Path):
    ensure_private_parent(path)
    with open(path, "a+", encoding="utf-8") as handle:
        set_permissions(path, PRIVATE_FILE_MODE)
        if fcntl is not None:
            while True:
                try:
                    fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
                    break
                except OSError as exc:  # pragma: no cover - signal interruption
                    if exc.errno == errno.EINTR:
                        continue
                    raise
        try:
            yield
        finally:
            if fcntl is not None:
                fcntl.flock(handle.fileno(), fcntl.LOCK_UN)

logfile, timestamp, companion, text = sys.argv[1:5]
logfile_path = Path(logfile)
entry = {
    "timestamp": timestamp,
    "companion": companion,
    "text": text,
}
with advisory_lock(lock_path_for(logfile_path)):
    with open(logfile_path, "a", encoding="utf-8") as handle:
        handle.write(json.dumps(entry, ensure_ascii=False) + "\n")
    set_permissions(logfile_path, PRIVATE_FILE_MODE)
print("Added.")
PY
}

cleanup_raw() {
    local max_age_days="${1:-$CLEANUP_RAW_DAYS_DEFAULT}"
    python3 - "$RAW_DIR" "$max_age_days" <<'PY'
import sys
import time
from pathlib import Path

raw_dir = Path(sys.argv[1])
max_age_days = int(sys.argv[2])

if max_age_days < 0:
    print("Error: --cleanup-raw expects a non-negative day count.", file=sys.stderr)
    sys.exit(1)

if not raw_dir.exists():
    print("No raw captures directory found.")
    sys.exit(0)

cutoff = time.time() - (max_age_days * 86400)
removed = 0
for raw_path in sorted(raw_dir.glob("session-*.raw")):
    try:
        if raw_path.stat().st_mtime < cutoff:
            raw_path.unlink()
            removed += 1
    except FileNotFoundError:
        pass

day_label = "day" if max_age_days == 1 else "days"
print(f"Removed {removed} raw capture file(s) older than {max_age_days} {day_label}.")
PY
}

require_glimmer_ui_script() {
    if [ -z "$GLIMMER_UI_SCRIPT" ] || [ ! -f "$GLIMMER_UI_SCRIPT" ]; then
        echo "glimmer-ui is required for this command but was not found." >&2
        exit 1
    fi
}

view_mattered() {
    local output_mode="${1:-pretty}"
    require_glimmer_ui_script
    python3 - "$GLIMMER_UI_SCRIPT" "$GLIMMER_DIR" "$output_mode" <<'PY'
import importlib.util
import json
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path


def load_module(path: str):
    loader = SourceFileLoader("glimmer_ui", path)
    spec = importlib.util.spec_from_loader("glimmer_ui", loader)
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module


def format_ts(module, value: str | None) -> str:
    parsed = module.parse_timestamp(value)
    if parsed is None:
        return value or "-"
    return parsed.strftime("%Y-%m-%d %H:%M")


module = load_module(sys.argv[1])
glimmer_dir = Path(sys.argv[2]).expanduser()
output_mode = sys.argv[3]
payload = module.build_mattered_view(module.build_index(glimmer_dir))

if output_mode == "json":
    print(json.dumps(payload, ensure_ascii=False))
    sys.exit(0)

if not payload["bubbles"]:
    print("No mattered bubbles yet.")
    sys.exit(0)

print(f'Mattered bubbles: {payload["count"]}')
print(
    f'Unreviewed: {payload["counts"]["unreviewed"]}  '
    f'Open: {payload["counts"]["open"]}  '
    f'Used: {payload["counts"]["used"]}  '
    f'Stale: {payload["counts"]["stale"]}'
)
print()

for bubble in payload["bubbles"]:
    project = bubble.get("project_name") or "-"
    state = bubble.get("review_state") or module.DEFAULT_REVIEW_STATE
    print(
        f'{bubble["id"]}  {format_ts(module, bubble.get("mattered_at") or bubble.get("timestamp"))}  '
        f'project={project}  state={state}'
    )
    print(f'  "{bubble.get("text", "")}"')
    if bubble.get("matter_note"):
        print(f'  note: {bubble["matter_note"]}')
    print()
PY
}

view_review() {
    local output_mode="${1:-pretty}"
    local review_filter="${2:-}"
    require_glimmer_ui_script
    python3 - "$GLIMMER_UI_SCRIPT" "$GLIMMER_DIR" "$output_mode" "$review_filter" <<'PY'
import importlib.util
import json
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path


def load_module(path: str):
    loader = SourceFileLoader("glimmer_ui", path)
    spec = importlib.util.spec_from_loader("glimmer_ui", loader)
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module


def format_ts(module, value: str | None) -> str:
    parsed = module.parse_timestamp(value)
    if parsed is None:
        return value or "-"
    return parsed.strftime("%Y-%m-%d %H:%M")


module = load_module(sys.argv[1])
glimmer_dir = Path(sys.argv[2]).expanduser()
output_mode = sys.argv[3]
review_filter = sys.argv[4]
payload = module.build_review_view(module.build_index(glimmer_dir))

if review_filter:
    if review_filter not in module.REVIEW_STATES:
        print(
            f"Invalid review state: {review_filter}. "
            f"Expected one of: {', '.join(module.REVIEW_STATES)}",
            file=sys.stderr,
        )
        sys.exit(1)
    payload = {
        "generated_at": payload["generated_at"],
        "counts": payload["counts"],
        "groups": {review_filter: payload["groups"][review_filter]},
    }

if output_mode == "json":
    print(json.dumps(payload, ensure_ascii=False))
    sys.exit(0)

if payload["counts"]["mattered"] == 0:
    print("No mattered bubbles to review yet.")
    sys.exit(0)

for review_state, bubbles in payload["groups"].items():
    print(f'{review_state} ({len(bubbles)})')
    if not bubbles:
        print("  none")
        print()
        continue
    for bubble in bubbles:
        project = bubble.get("project_name") or "-"
        reviewed_at = format_ts(module, bubble.get("reviewed_at"))
        print(f'  {bubble["id"]}  project={project}  reviewed={reviewed_at}')
        print(f'    "{bubble.get("text", "")}"')
        if bubble.get("matter_note"):
            print(f'    note: {bubble["matter_note"]}')
    print()
PY
}

mark_bubble() {
    local bubble_ref="$1"
    local marked="$2"
    local note="${3:-}"
    require_glimmer_ui_script
    python3 - "$GLIMMER_UI_SCRIPT" "$GLIMMER_DIR" "$bubble_ref" "$marked" "$note" <<'PY'
import importlib.util
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path


def load_module(path: str):
    loader = SourceFileLoader("glimmer_ui", path)
    spec = importlib.util.spec_from_loader("glimmer_ui", loader)
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module


module = load_module(sys.argv[1])
glimmer_dir = Path(sys.argv[2]).expanduser()
bubble_ref = sys.argv[3]
marked = sys.argv[4] == "1"
note = sys.argv[5]
index = module.build_index(glimmer_dir)

if not index["bubbles"]:
    print("No bubbles available.", file=sys.stderr)
    sys.exit(1)

if bubble_ref == "latest":
    bubble = index["bubbles"][0]
else:
    bubble = next((item for item in index["bubbles"] if item.get("id") == bubble_ref), None)

if bubble is None:
    print(f"Bubble not found: {bubble_ref}", file=sys.stderr)
    sys.exit(1)

matters_path = glimmer_dir / module.MATTERS_FILE
matter = module.mutate_matters(
    matters_path,
    lambda matters: module.upsert_matter(
        matters,
        bubble["id"],
        marked=marked,
        note=note,
    ),
)

if marked:
    print(f'Marked {bubble["id"]}.')
    if matter and matter.get("note"):
        print(f'Note: {matter["note"]}')
else:
    print(f'Unmarked {bubble["id"]}.')
PY
}

set_review_state() {
    local bubble_ref="$1"
    local review_state="$2"
    require_glimmer_ui_script
    python3 - "$GLIMMER_UI_SCRIPT" "$GLIMMER_DIR" "$bubble_ref" "$review_state" <<'PY'
import importlib.util
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path


def load_module(path: str):
    loader = SourceFileLoader("glimmer_ui", path)
    spec = importlib.util.spec_from_loader("glimmer_ui", loader)
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module


module = load_module(sys.argv[1])
glimmer_dir = Path(sys.argv[2]).expanduser()
bubble_ref = sys.argv[3]
review_state = sys.argv[4]
index = module.build_index(glimmer_dir)

if not index["bubbles"]:
    print("No bubbles available.", file=sys.stderr)
    sys.exit(1)

if bubble_ref == "latest":
    bubble = index["bubbles"][0]
else:
    bubble = next((item for item in index["bubbles"] if item.get("id") == bubble_ref), None)

if bubble is None:
    print(f"Bubble not found: {bubble_ref}", file=sys.stderr)
    sys.exit(1)

matters_path = glimmer_dir / module.MATTERS_FILE
try:
    matter = module.mutate_matters(
        matters_path,
        lambda matters: module.update_review_state(
            matters,
            bubble["id"],
            review_state,
        ),
    )
except KeyError:
    print("Bubble must be marked as mattered first.", file=sys.stderr)
    sys.exit(1)
except ValueError as exc:
    print(str(exc), file=sys.stderr)
    sys.exit(1)
print(f'Set {bubble["id"]} to {matter["review_state"]}.')
PY
}

show_help() {
    echo "Usage: glimmer-log [OPTIONS]"
    echo ""
    echo "  (no args)         Show all captured bubbles"
    echo "  -n NUM            Show last NUM bubbles"
    echo "  --grep TEXT       Search bubble text in log.jsonl"
    echo "  --session ID      Show bubbles from a specific session"
    echo "  --session latest  Show the newest session"
    echo "  --sessions        List known sessions"
    echo "  --project NAME    Filter session views by exact project name"
    echo "  --branch NAME     Filter session views by exact git branch"
    echo "  --cwd PATH        Filter session views by exact cwd"
    echo "  --repo-root-only  Filter session views to repo-root sessions"
    echo "  --mattered        Show bubbles marked as mattered"
    echo "  --review [STATE]  Show mattered bubbles grouped by review state"
    echo "  --mark ID         Mark a bubble as mattered (or use latest)"
    echo "  --unmark ID       Remove mattered mark from a bubble"
    echo "  --note TEXT       Optional note for --mark"
    echo "  --review-state ID STATE"
    echo "                    Set review state: unreviewed, open, used, stale"
    echo "  --cleanup-raw     Remove raw capture files older than 14 days"
    echo "  --cleanup-raw N   Remove raw capture files older than N days"
    echo "  --add \"text\"      Manually add a bubble"
    echo "  --json            Raw legacy JSONL output"
    echo "  --stats           Show legacy log statistics"
    echo "  -h, --help        Show this help"
}

MODE="legacy"
LEGACY_MODE="pretty"
OUTPUT_MODE="pretty"
LIMIT=0
SESSION_REF=""
PROJECT_FILTER=""
BRANCH_FILTER=""
CWD_FILTER=""
REPO_ROOT_ONLY=0
GREP_TEXT=""
REVIEW_FILTER=""
MARK_REF=""
UNMARK_REF=""
NOTE_TEXT=""
REVIEW_STATE_REF=""
REVIEW_STATE_VALUE=""

while [ $# -gt 0 ]; do
    case "$1" in
        --grep)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --grep <text>" >&2
                exit 1
            fi
            GREP_TEXT="$2"
            shift 2
            ;;
        --json)
            OUTPUT_MODE="json"
            if [ "$MODE" = "legacy" ]; then
                LEGACY_MODE="json"
            fi
            shift
            ;;
        --stats)
            MODE="legacy"
            LEGACY_MODE="stats"
            shift
            ;;
        --sessions)
            MODE="sessions"
            shift
            ;;
        --session)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --session <id|latest>" >&2
                exit 1
            fi
            SESSION_REF="$2"
            shift 2
            ;;
        --project)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --project <name>" >&2
                exit 1
            fi
            PROJECT_FILTER="$2"
            shift 2
            ;;
        --branch)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --branch <name>" >&2
                exit 1
            fi
            BRANCH_FILTER="$2"
            shift 2
            ;;
        --cwd)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --cwd <path>" >&2
                exit 1
            fi
            CWD_FILTER="$2"
            shift 2
            ;;
        --repo-root-only)
            REPO_ROOT_ONLY=1
            shift
            ;;
        --mattered)
            MODE="mattered"
            shift
            ;;
        --review)
            MODE="review"
            if [ $# -ge 2 ] && [[ ! "${2:-}" =~ ^- ]]; then
                REVIEW_FILTER="$2"
                shift 2
            else
                shift
            fi
            ;;
        --mark)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --mark <id|latest>" >&2
                exit 1
            fi
            MARK_REF="$2"
            shift 2
            ;;
        --unmark)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --unmark <id|latest>" >&2
                exit 1
            fi
            UNMARK_REF="$2"
            shift 2
            ;;
        --note)
            if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
                echo "Usage: glimmer-log --note <text>" >&2
                exit 1
            fi
            NOTE_TEXT="$2"
            shift 2
            ;;
        --review-state)
            if [ $# -lt 3 ] || [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
                echo "Usage: glimmer-log --review-state <id|latest> <state>" >&2
                exit 1
            fi
            REVIEW_STATE_REF="$2"
            REVIEW_STATE_VALUE="$3"
            shift 3
            ;;
        -n)
            if ! [[ "${2:-}" =~ ^[0-9]+$ ]]; then
                echo "Error: -n expects a non-negative integer." >&2
                exit 1
            fi
            LIMIT="$2"
            shift 2
            ;;
        --add)
            shift
            if [ -z "${1:-}" ]; then
                echo "Usage: glimmer-log --add \"bubble text here\"" >&2
                exit 1
            fi
            add_bubble "$*"
            exit 0
            ;;
        --cleanup-raw)
            if [ -n "${2:-}" ] && [[ "${2:-}" =~ ^[0-9]+$ ]]; then
                cleanup_raw "$2"
                exit 0
            fi
            cleanup_raw
            exit 0
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            show_help >&2
            exit 1
            ;;
    esac
done

if [ -n "$PROJECT_FILTER" ] || [ -n "$BRANCH_FILTER" ] || [ -n "$CWD_FILTER" ] || [ "$REPO_ROOT_ONLY" -eq 1 ]; then
    if [ "$MODE" = "legacy" ]; then
        MODE="sessions"
    fi
fi

if [ -n "$MARK_REF" ]; then
    mark_bubble "$MARK_REF" "1" "$NOTE_TEXT"
    exit 0
fi

if [ -n "$UNMARK_REF" ]; then
    mark_bubble "$UNMARK_REF" "0" ""
    exit 0
fi

if [ -n "$REVIEW_STATE_REF" ]; then
    set_review_state "$REVIEW_STATE_REF" "$REVIEW_STATE_VALUE"
    exit 0
fi

if [ "$MODE" = "mattered" ]; then
    view_mattered "$OUTPUT_MODE"
    exit 0
fi

if [ "$MODE" = "review" ]; then
    view_review "$OUTPUT_MODE" "$REVIEW_FILTER"
    exit 0
fi

if [ -n "$SESSION_REF" ] || [ "$MODE" = "sessions" ]; then
    view_sessions "$SESSION_REF" "$PROJECT_FILTER" "$BRANCH_FILTER" "$CWD_FILTER" "$REPO_ROOT_ONLY"
    exit 0
fi

require_logfile
view_legacy "$LEGACY_MODE" "$LIMIT" "$GREP_TEXT"
