#!/usr/bin/env bash
#
# glimmer-claude — Run Claude Code with Glimmer speech bubble logging.
#
# Wraps `claude` inside `script` to capture terminal output, then runs
# a background watcher that extracts speech bubbles and logs them to
# $GLIMMER_DATA_DIR/log.jsonl (default: ~/.claude/glimmer/log.jsonl)
#
# Usage: glimmer-claude [any claude args...]
#

set -euo pipefail
umask 077

GLIMMER_DIR="${GLIMMER_DATA_DIR:-$HOME/.claude/glimmer}"
RAW_DIR="$GLIMMER_DIR/raw"
SESSIONS_DIR="$GLIMMER_DIR/sessions"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WATCHER="${GLIMMER_WATCHER:-}"
SESSION_HELPER="${GLIMMER_SESSION_HELPER:-}"
KEEP_RAW_CAPTURE="${GLIMMER_KEEP_RAW:-1}"
LOG_HELPER="${GLIMMER_LOG_HELPER:-}"

if [ -z "$WATCHER" ]; then
    if command -v glimmer-watcher.py >/dev/null 2>&1; then
        WATCHER="$(command -v glimmer-watcher.py)"
    elif [ -x "$SCRIPT_DIR/glimmer-watcher.py" ]; then
        WATCHER="$SCRIPT_DIR/glimmer-watcher.py"
    else
        WATCHER="$HOME/.local/bin/glimmer-watcher.py"
    fi
fi

if [ -z "$SESSION_HELPER" ]; then
    if command -v glimmer-session.py >/dev/null 2>&1; then
        SESSION_HELPER="$(command -v glimmer-session.py)"
    elif [ -x "$SCRIPT_DIR/glimmer-session.py" ]; then
        SESSION_HELPER="$SCRIPT_DIR/glimmer-session.py"
    else
        SESSION_HELPER="$HOME/.local/bin/glimmer-session.py"
    fi
fi

if [ -z "$LOG_HELPER" ]; then
    if command -v glimmer-log >/dev/null 2>&1; then
        LOG_HELPER="$(command -v glimmer-log)"
    elif [ -x "$SCRIPT_DIR/glimmer-log" ]; then
        LOG_HELPER="$SCRIPT_DIR/glimmer-log"
    else
        LOG_HELPER="$HOME/.local/bin/glimmer-log"
    fi
fi

BRIEF_ON_START="${GLIMMER_BRIEF_ON_START:-0}"
BRIEF_FORMAT="${GLIMMER_BRIEF_FORMAT:-plain}"
GLIMMER_SESSION_PROFILE="${GLIMMER_PROFILE:-}"
CLAUDE_ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --glimmer-brief)
            BRIEF_ON_START=1
            shift
            ;;
        --glimmer-brief-markdown)
            BRIEF_ON_START=1
            BRIEF_FORMAT="markdown"
            shift
            ;;
        --profile)
            GLIMMER_SESSION_PROFILE="$2"
            shift 2
            ;;
        --)
            shift
            while [ $# -gt 0 ]; do
                CLAUDE_ARGS+=("$1")
                shift
            done
            ;;
        *)
            CLAUDE_ARGS+=("$1")
            shift
            ;;
    esac
done

if ! command -v claude >/dev/null 2>&1; then
    echo "Error: 'claude' is not in PATH." >&2
    exit 1
fi

if ! command -v script >/dev/null 2>&1; then
    echo "Error: 'script' is required but not installed." >&2
    exit 1
fi

if [ ! -x "$WATCHER" ]; then
    echo "Error: could not find glimmer-watcher.py." >&2
    echo "Install Glimmer first or set GLIMMER_WATCHER to its path." >&2
    exit 1
fi

if [ ! -x "$SESSION_HELPER" ]; then
    echo "Error: could not find glimmer-session.py." >&2
    echo "Install Glimmer first or set GLIMMER_SESSION_HELPER to its path." >&2
    exit 1
fi

mkdir -p "$GLIMMER_DIR" "$RAW_DIR" "$SESSIONS_DIR"
chmod 700 "$GLIMMER_DIR" "$RAW_DIR" "$SESSIONS_DIR" 2>/dev/null || true

# Get companion name from config
COMPANION_NAME=$(python3 -c "
import json, os
try:
    cfg = json.load(open(os.path.expanduser('~/.claude.json')))
    print(cfg.get('companion', {}).get('name', 'Glimmer'))
except: print('Glimmer')
" 2>/dev/null || echo "Glimmer")

# Session-specific raw capture file
SESSION_ID="$(date +%Y%m%d-%H%M%S)-$$"
TYPESCRIPT="$RAW_DIR/session-${SESSION_ID}.raw"
MANIFEST_PATH="$SESSIONS_DIR/${SESSION_ID}.json"
STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%S+00:00)"
PWD_VALUE="${PWD:-$(pwd)}"
WATCHER_PID=""

if [ -z "$GLIMMER_SESSION_PROFILE" ]; then
    _pdir="${PWD:-$(pwd)}"
    while [ "$_pdir" != "/" ]; do
        if [ -f "$_pdir/.glimmer-profile" ]; then
            GLIMMER_SESSION_PROFILE="$(head -1 "$_pdir/.glimmer-profile" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
            break
        fi
        _pdir="$(dirname "$_pdir")"
    done
    unset _pdir
fi
export GLIMMER_SESSION_PROFILE

write_session_manifest() {
    python3 "$SESSION_HELPER" manifest "$MANIFEST_PATH" "$SESSION_ID" "$STARTED_AT" "$COMPANION_NAME" "$TYPESCRIPT" "$PWD_VALUE" "${CLAUDE_ARGS[@]}"
}

show_start_brief() {
    if [ "$BRIEF_ON_START" != "1" ]; then
        return
    fi
    if [ ! -x "$LOG_HELPER" ]; then
        echo "[glimmer-claude] Brief requested, but glimmer-log was not found." >&2
        return
    fi

    echo "[glimmer-claude] Brief for this project"
    if [ "$BRIEF_FORMAT" = "markdown" ]; then
        "$LOG_HELPER" --brief --cwd "$PWD_VALUE" --markdown || true
    else
        "$LOG_HELPER" --brief --cwd "$PWD_VALUE" --plain || true
    fi
    echo ""
}

finalize_session_manifest() {
    local ended_at="$1"
    python3 "$SESSION_HELPER" finalize "$MANIFEST_PATH" "$SESSION_ID" "$ended_at"
}

cleanup() {
    local exit_code=$?
    local ended_at

    # Finish manifest + watcher shutdown even if the user presses Ctrl-C again.
    trap '' INT TERM

    ended_at="$(date -u +%Y-%m-%dT%H:%M:%S+00:00)"
    finalize_session_manifest "$ended_at"

    if [ -n "${WATCHER_PID:-}" ] && kill -0 "$WATCHER_PID" 2>/dev/null; then
        kill -TERM "$WATCHER_PID" 2>/dev/null || true
        wait "$WATCHER_PID" 2>/dev/null || true
    fi
    # Keep raw transcripts only when explicitly requested.
    if [ "$KEEP_RAW_CAPTURE" = "0" ] && [ -f "$TYPESCRIPT" ]; then
        rm -f "$TYPESCRIPT"
    elif [ -f "$TYPESCRIPT" ] && [ ! -s "$TYPESCRIPT" ]; then
        rm -f "$TYPESCRIPT"
    fi
    printf '\r\033[2K\n'
    echo "[glimmer-claude] Session ended. Bubbles saved to $GLIMMER_DIR/log.jsonl"
    return "$exit_code"
}
trap cleanup EXIT

# Create the raw file so the watcher can start tailing immediately
touch "$TYPESCRIPT"
chmod 600 "$TYPESCRIPT" 2>/dev/null || true
write_session_manifest

echo "Starting Claude Code with Glimmer logging..."
echo "  Companion: $COMPANION_NAME"
echo "  Session:   $SESSION_ID"
echo "  Log file:  $GLIMMER_DIR/log.jsonl"
echo ""

show_start_brief

# Start the watcher in background
python3 "$WATCHER" "$TYPESCRIPT" "$COMPANION_NAME" "$SESSION_ID" "$MANIFEST_PATH" &
WATCHER_PID=$!

# Build the claude command with properly quoted args
CLAUDE_CMD="claude"
for arg in "${CLAUDE_ARGS[@]}"; do
    CLAUDE_CMD+=" $(printf '%q' "$arg")"
done

# Run claude inside `script` to capture terminal output
# -q: quiet (don't print script's own messages)
# -f: flush output after each write
# -c: command to run
script -q -f "$TYPESCRIPT" -c "$CLAUDE_CMD"
